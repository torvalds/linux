[
    {
        "id": "c2b4",
        "name": "Soft lockup alarm will be not generated after delete the prio 0 filter of the chain",
        "category": [
            "filter",
            "chain"
        ],
	"plugins": {
		"requires": "nsPlugin"
	},
        "setup": [
            "$TC qdisc add dev $DUMMY root handle 1: htb default 1",
            "$TC chain add dev $DUMMY",
            "$TC filter del dev $DUMMY chain 0 parent 1: prio 0"
        ],
        "cmdUnderTest": "$TC filter add dev $DUMMY chain 0 parent 1:",
        "expExitCode": "2",
        "verifyCmd": "$TC chain ls dev $DUMMY",
        "matchPattern": "chain parent 1: chain 0",
        "matchCount": "1",
        "teardown": [
            "$TC qdisc del dev $DUMMY root handle 1: htb default 1"
        ]
    },
    {
        "id": "b7e3",
        "name": "Empty fw filter on shared block - rejected at config time",
        "category": [
            "filter",
            "fw"
        ],
        "plugins": {
            "requires": "nsPlugin"
        },
        "setup": [
            "$TC qdisc add dev $DEV1 egress_block 1 clsact"
        ],
        "cmdUnderTest": "$TC filter add block 1 protocol ip prio 1 fw",
        "expExitCode": "2",
        "verifyCmd": "$TC filter show block 1",
        "matchPattern": "fw",
        "matchCount": "0",
        "teardown": [
            "$TC qdisc del dev $DEV1 clsact"
        ]
    },
    {
        "id": "c8f4",
        "name": "Flow filter on shared block without baseclass - rejected at config time",
        "category": [
            "filter",
            "flow"
        ],
        "plugins": {
            "requires": "nsPlugin"
        },
        "setup": [
            "$TC qdisc add dev $DEV1 ingress_block 1 clsact"
        ],
        "cmdUnderTest": "$TC filter add block 1 protocol ip prio 1 handle 1 flow map key dst",
        "expExitCode": "2",
        "verifyCmd": "$TC filter show block 1",
        "matchPattern": "flow",
        "matchCount": "0",
        "teardown": [
            "$TC qdisc del dev $DEV1 clsact"
        ]
    }
]
