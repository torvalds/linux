	};

	pwm0 {
		/omit-if-no-ref/
		pwm0m0_ch0: pwm0m0-ch0 {
			rockchip,pins =
				/* pwm0m0_ch0 */
				<0 RK_PA1 1 &pcfg_pull_none_drv_level_0>;
		};
		/omit-if-no-ref/
		pwm0m0_ch1: pwm0m0-ch1 {
			rockchip,pins =
				/* pwm0m0_ch1 */
				<0 RK_PA5 2 &pcfg_pull_none_drv_level_0>;
		};
		/omit-if-no-ref/
		pwm0m0_ch2: pwm0m0-ch2 {
			rockchip,pins =
