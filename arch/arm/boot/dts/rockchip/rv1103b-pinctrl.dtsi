				<0 RK_PA0 4 &pcfg_pull_none>;
		};
		/omit-if-no-ref/
		psram_spi_cs0n: psram-spi-cs0n {
			rockchip,pins =
				/* psram_spi_cs0n */
				<0 RK_PA4 4 &pcfg_pull_none>;
