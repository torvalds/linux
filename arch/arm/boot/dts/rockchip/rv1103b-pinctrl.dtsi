				<2 RK_PB1 3 &pcfg_pull_none_drv_level_0>;
		};
	};

	pwm2 {
		/omit-if-no-ref/
		pwm2m0_ch0: pwm2m0-ch0 {
			rockchip,pins =
				/* pwm2m0_ch0 */
				<1 RK_PB0 4 &pcfg_pull_none_drv_level_0>;
		};
		/omit-if-no-ref/
		pwm2m0_ch1: pwm2m0-ch1 {
			rockchip,pins =
