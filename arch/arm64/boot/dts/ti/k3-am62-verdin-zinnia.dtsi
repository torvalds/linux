		"",
		"",
		"",
		"DI2_EN", /* SODIMM 218 */
		"",
		"",
		"",
		"DI2_RB", /* SODIMM 216 */ /* 40 */
		"DO3_EN", /* SODIMM 220 */
		"DI3_EN", /* SODIMM 222 */
		"",
		"",
		"",
		"",
		"",
