					drive-strength = <2>;
					bias-disable;
				};

				rts-pins {
					pins = "gpio77";
					function = "qup2_se3";
					drive-strength = <2>;
					bias-disable;
				};

				tx-pins {
					pins = "gpio78";
					function = "qup2_se3";
					drive-strength = <2>;
					bias-disable;
				};

				rx-pins {
					pins = "gpio79";
					function = "qup2_se3";
					drive-strength = <2>;
					bias-disable;
				};
			};

			qup_uart21_default: qup-uart21-default-state {
				tx-pins {
					pins = "gpio86";
					function = "qup2_se5";
					drive-strength = <2>;
					bias-disable;
				};

				rx-pins {
					pins = "gpio87";
					function = "qup2_se5";
					drive-strength = <2>;
					bias-disable;
				};
			};

			qup_uart22_default: qup-uart22-default-state {
				tx-pins {
					pins = "gpio90";
					function = "qup2_se6";
					drive-strength = <2>;
					bias-disable;
				};

				rx-pins {
					pins = "gpio91";
					function = "qup2_se6";
					drive-strength = <2>;
					bias-disable;
				};
			};
		};

