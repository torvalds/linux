			compatible = "qcom,glymur-cnoc-cfg";
			reg = <0x0 0x01600000 0x0 0x6600>;
			qcom,bcm-voters = <&apps_bcm_voter>;
			#interconnect-cells = <2>;
		};

		system_noc: interconnect@1680000 {
			compatible = "qcom,glymur-system-noc";
